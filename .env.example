# Railway injects DATABASE_URL automatically when you add the Postgres plugin
DATABASE_URL=postgres://user:pass@host:5432/memewatch

# Optional in Phase 1 (deployer fingerprint gate degrades gracefully without it)
HELIUS_API_KEY=

# Telegram backup alerts (create bot via @BotFather, get chat id via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PORT=3000

# Optional: AI analyst note on TRIGGER alerts (console.anthropic.com)
ANTHROPIC_API_KEY=
# Gemini key from aistudio.google.com/apikey — powers analyst notes (Flash) + AI review (Pro)
GEMINI_API_KEY=

# Protects wallet-admin endpoints on the public dashboard. Set to any long random string.
ADMIN_KEY=
